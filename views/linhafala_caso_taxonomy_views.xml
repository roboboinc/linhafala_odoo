<?xml version="1.0"?>
<odoo>

    <!-- ============================================================ -->
    <!-- Classificação do Caso (visível ao utilizador)                -->
    <!-- ============================================================ -->
    <record id="linhafala_caso_classificacao_view_tree" model="ir.ui.view">
        <field name="name">linhafala.caso.classificacao.tree</field>
        <field name="model">linhafala.caso.classificacao</field>
        <field name="arch" type="xml">
            <tree string="Classificações">
                <field name="name" />
                <field name="active" optional="show" />
            </tree>
        </field>
    </record>

    <record id="linhafala_caso_classificacao_view_form" model="ir.ui.view">
        <field name="name">linhafala.caso.classificacao.form</field>
        <field name="model">linhafala.caso.classificacao</field>
        <field name="arch" type="xml">
            <form string="Classificação do Caso">
                <sheet>
                    <widget name="web_ribbon" title="Arquivado" bg_color="bg-danger"
                        attrs="{'invisible': [('active', '=', True)]}" />
                    <div class="oe_title">
                        <label for="name" />
                        <h1><field name="name" /></h1>
                    </div>
                    <group>
                        <field name="active" />
                    </group>
                    <group string="Tipos de Caso associados">
                        <field name="tipo_ids" nolabel="1" context="{'active_test': False}">
                            <tree editable="bottom">
                                <field name="name" />
                                <field name="subcategoria_auto_id" />
                                <field name="area_id" />
                                <field name="categoria_juridica_id" />
                                <field name="enquadramento_id" />
                                <field name="active" />
                            </tree>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="linhafala_caso_classificacao_action" model="ir.actions.act_window">
        <field name="name">Classificação de Caso</field>
        <field name="res_model">linhafala.caso.classificacao</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Gerir Classificações de casos
            </p>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Tipo do Caso (visível ao utilizador)                         -->
    <!-- ============================================================ -->
    <record id="linhafala_caso_tipo_view_tree" model="ir.ui.view">
        <field name="name">linhafala.caso.tipo.tree</field>
        <field name="model">linhafala.caso.tipo</field>
        <field name="arch" type="xml">
            <tree string="Tipos de Caso">
                <field name="name" />
                <field name="classificacao_id" />
                <field name="subcategoria_auto_id" />
                <field name="area_id" />
                <field name="categoria_juridica_id" />
                <field name="enquadramento_id" />
                <field name="active" optional="show" />
            </tree>
        </field>
    </record>

    <record id="linhafala_caso_tipo_view_form" model="ir.ui.view">
        <field name="name">linhafala.caso.tipo.form</field>
        <field name="model">linhafala.caso.tipo</field>
        <field name="arch" type="xml">
            <form string="Tipo do Caso">
                <sheet>
                    <widget name="web_ribbon" title="Arquivado" bg_color="bg-danger"
                        attrs="{'invisible': [('active', '=', True)]}" />
                    <div class="oe_title">
                        <label for="name" />
                        <h1><field name="name" /></h1>
                    </div>
                    <group>
                        <group string="Selecção do utilizador">
                            <field name="classificacao_id" />
                            <field name="active" />
                        </group>
                        <group string="Dimensões automáticas">
                            <field name="subcategoria_auto_id" />
                            <field name="area_id" />
                            <field name="categoria_juridica_id" />
                            <field name="enquadramento_id" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="linhafala_caso_tipo_action" model="ir.actions.act_window">
        <field name="name">Tipo de Caso</field>
        <field name="res_model">linhafala.caso.tipo</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Gerir Tipos de caso e as suas dimensões automáticas
            </p>
        </field>
    </record>

